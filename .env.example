# Public image to deploy
OPENCLAW_IMAGE=akimsoule/openclaw-thinkcenter:latest

# Container name/project
COMPOSE_PROJECT_NAME=openclaw-thinkcenter

# Persist OpenClaw state on host
OPENCLAW_CONFIG_DIR=${HOME}/.openclaw-thinkcenter
OPENCLAW_WORKSPACE_DIR=${HOME}/.openclaw-thinkcenter/workspace
OPENCLAW_CONTAINER_UID=1000

# Gateway network
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Control UI remote access allowlist
# Option 2 (advanced): set explicit JSON list of origins
# IMPORTANT: keep the whole JSON in single quotes in this shell-based .env
CONTROL_UI_ALLOWED_ORIGINS_JSON='["http://192.168.0.63:18789","http://127.0.0.1:18789","http://localhost:18789"]'

# DANGEROUS: disable Control UI device identity checks (for non-secure HTTP LAN access)
CONTROL_UI_DISABLE_DEVICE_IDENTITY=true

# Runtime channel/model secrets (keep only in .env, never commit)
TELEGRAM_BOT_TOKEN=
MOONSHOT_API_KEY=

# Telegram access policy
TELEGRAM_DM_POLICY=open
TELEGRAM_GROUP_POLICY=open
TELEGRAM_GROUP_ALLOW_FROM=

# Primary model (NVIDIA integrator):
# Leave as-is unless you want to force Moonshot instead.
PRIMARY_MODEL=nvidia/moonshotai/kimi-k2.5

# Typing indicator TTL (seconds) in chat channels (Telegram, Slack, etc.)
# When the assistant is generating, it will send "typing..." and stop after this many seconds.
# Increase if your model responses take longer.
TYPING_INTERVAL_SECONDS=120

# Optional tuning for explicit NVIDIA model registration
PRIMARY_MODEL_CONTEXT_WINDOW=131072
PRIMARY_MODEL_MAX_TOKENS=16384
