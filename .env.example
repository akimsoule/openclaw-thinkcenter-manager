# Public image to deploy
OPENCLAW_IMAGE=akimsoule/openclaw-thinkcenter:latest

# Container name/project
COMPOSE_PROJECT_NAME=openclaw-thinkcenter

# Persist OpenClaw state on host
OPENCLAW_CONFIG_DIR=${HOME}/.openclaw-thinkcenter
OPENCLAW_WORKSPACE_DIR=${HOME}/.openclaw-thinkcenter/workspace

# Gateway network
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Runtime channel/model secrets (keep only in .env, never commit)
TELEGRAM_BOT_TOKEN=
NVIDIA_API_KEY=

# Telegram access policy
TELEGRAM_DM_POLICY=open
TELEGRAM_GROUP_POLICY=open
TELEGRAM_GROUP_ALLOW_FROM=

# Ollama host on ThinkCentre
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_API_KEY=ollama-local
